      "location": "Global",
      "tags": "[parameters('tags')]",
      "properties": {
        "description": "Alert on function execution failures",
        "severity": 1,
        "enabled": true,
        "scopes": [
          "[parameters('functionAppResourceId')]"
        ],
        "evaluationFrequency": "PT1M",
        "windowSize": "PT5M",
        "criteria": {
          "odata.type": "Microsoft.Azure.Monitor.SingleResourceMultipleMetricCriteria",
          "allOf": [
            {
              "name": "FunctionFailures",
              "metricName": "FunctionExecutionCount",
              "metricNamespace": "Microsoft.Web/sites",
              "operator": "GreaterThan",
              "threshold": 5,
              "timeAggregation": "Total",
              "criterionType": "StaticThresholdCriterion",
              "dimensions": [
                {
                  "name": "FunctionName",
                  "operator": "Include",
                  "values": [
                    "*"
                  ]
                }
              ]
            }
          ]
        },
        "actions": "[if(or(not(equals(parameters('actionGroupId'), '')), not(parameters('enableAlerts'))), createArray(createObject('actionGroupId', variables('effectiveActionGroupId'), 'webHookProperties', createObject())), createArray())]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/actionGroups', format('{0}-alerts-{1}', parameters('prefix'), parameters('environment')))]"
      ]
    },
    {
      "condition": "[parameters('enableAlerts')]",
      "type": "Microsoft.Insights/metricAlerts",
      "apiVersion": "2018-03-01",
      "name": "[format('{0}-alert-availability-{1}', parameters('prefix'), parameters('environment'))]",
      "location": "Global",
      "tags": "[parameters('tags')]",
      "properties": {
        "description": "Alert when service availability drops",
        "severity": 1,
        "enabled": true,
        "scopes": [
          "[parameters('appInsightsResourceId')]"
        ],
        "evaluationFrequency": "PT1M",
        "windowSize": "PT5M",
        "criteria": {
          "odata.type": "Microsoft.Azure.Monitor.SingleResourceMultipleMetricCriteria",
          "allOf": [
            {
              "name": "LowAvailability",
              "metricName": "availabilityResults/availabilityPercentage",
              "metricNamespace": "microsoft.insights/components",
              "operator": "LessThan",
              "threshold": 99,
              "timeAggregation": "Average",
              "criterionType": "StaticThresholdCriterion"
            }
          ]
        },
        "actions": "[if(or(not(equals(parameters('actionGroupId'), '')), not(parameters('enableAlerts'))), createArray(createObject('actionGroupId', variables('effectiveActionGroupId'), 'webHookProperties', createObject())), createArray())]"
