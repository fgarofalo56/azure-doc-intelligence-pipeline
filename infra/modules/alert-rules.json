    },
    "docProcessingErrorAlertId": {
      "type": "string",
      "metadata": {
        "description": "Document processing error alert resource ID"
      },
      "value": "[if(parameters('enableAlerts'), resourceId('Microsoft.Insights/scheduledQueryRules', format('{0}-alert-doc-processing-{1}', parameters('prefix'), parameters('environment'))), '')]"
