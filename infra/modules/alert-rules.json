    {
      "condition": "[and(parameters('enableAlerts'), not(equals(parameters('cosmosDbResourceId'), '')))]",
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2023-03-15-preview",
      "name": "[format('{0}-alert-dlq-depth-{1}', parameters('prefix'), parameters('environment'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "displayName": "Dead Letter Queue Depth Alert",
        "description": "[format('Alert when dead letter queue exceeds {0} items', parameters('dlqDepthThreshold'))]",
        "severity": 2,
        "enabled": true,
        "evaluationFrequency": "PT15M",
        "scopes": [
          "[parameters('appInsightsResourceId')]"
        ],
        "windowSize": "PT15M",
        "criteria": {
          "allOf": [
            {
              "query": "            customMetrics\r\n            | where name == \"dlq_depth\" or name == \"dead_letter_queue_depth\"\r\n            | summarize DLQDepth = max(value) by bin(timestamp, 5m)\r\n            | where DLQDepth > ${dlqDepthThreshold}\r\n          ",
              "timeAggregation": "Count",
              "operator": "GreaterThan",
              "threshold": 0,
              "failingPeriods": {
                "numberOfEvaluationPeriods": 1,
                "minFailingPeriodsToAlert": 1
              }
            }
          ]
        },
        "actions": {
          "actionGroups": "[if(or(not(equals(parameters('actionGroupId'), '')), not(parameters('enableAlerts'))), createArray(variables('effectiveActionGroupId')), createArray())]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/actionGroups', format('{0}-alerts-{1}', parameters('prefix'), parameters('environment')))]"
      ]
    },
    {
      "condition": "[parameters('enableAlerts')]",
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2023-03-15-preview",
      "name": "[format('{0}-alert-restarts-{1}', parameters('prefix'), parameters('environment'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "displayName": "Function App Restart Alert",
        "description": "[format('Alert when function app restarts more than {0} times in 1 hour', parameters('restartThreshold'))]",
        "severity": 2,
        "enabled": true,
        "evaluationFrequency": "PT15M",
        "scopes": [
          "[parameters('appInsightsResourceId')]"
        ],
        "windowSize": "PT1H",
        "criteria": {
          "allOf": [
            {
              "query": "            traces\r\n            | where message contains \"Host started\" or message contains \"Host initialized\"\r\n            | summarize RestartCount = count() by bin(timestamp, 1h)\r\n            | where RestartCount > ${restartThreshold}\r\n          ",
              "timeAggregation": "Count",
              "operator": "GreaterThan",
              "threshold": 0,
              "failingPeriods": {
                "numberOfEvaluationPeriods": 1,
                "minFailingPeriodsToAlert": 1
              }
            }
          ]
        },
        "actions": {
          "actionGroups": "[if(or(not(equals(parameters('actionGroupId'), '')), not(parameters('enableAlerts'))), createArray(variables('effectiveActionGroupId')), createArray())]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/actionGroups', format('{0}-alerts-{1}', parameters('prefix'), parameters('environment')))]"
      ]
    },
    {
      "condition": "[parameters('enableAlerts')]",
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2023-03-15-preview",
      "name": "[format('{0}-alert-circuit-breaker-{1}', parameters('prefix'), parameters('environment'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "displayName": "Circuit Breaker Open Alert",
        "description": "Alert when circuit breaker opens",
        "severity": 1,
        "enabled": true,
        "evaluationFrequency": "PT5M",
        "scopes": [
          "[parameters('appInsightsResourceId')]"
        ],
        "windowSize": "PT5M",
        "criteria": {
          "allOf": [
            {
              "query": "            traces\r\n            | where message contains \"circuit breaker\" and (message contains \"opened\" or message contains \"OPEN\")\r\n            | summarize OpenCount = count() by bin(timestamp, 5m)\r\n            | where OpenCount > 0\r\n          ",
              "timeAggregation": "Count",
              "operator": "GreaterThan",
              "threshold": 0,
              "failingPeriods": {
                "numberOfEvaluationPeriods": 1,
                "minFailingPeriodsToAlert": 1
              }
            }
          ]
        },
        "actions": {
          "actionGroups": "[if(or(not(equals(parameters('actionGroupId'), '')), not(parameters('enableAlerts'))), createArray(variables('effectiveActionGroupId')), createArray())]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/actionGroups', format('{0}-alerts-{1}', parameters('prefix'), parameters('environment')))]"
      ]
    },
    {
      "condition": "[parameters('enableAlerts')]",
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2023-03-15-preview",
      "name": "[format('{0}-alert-doc-processing-{1}', parameters('prefix'), parameters('environment'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "displayName": "Document Processing Error Alert",
        "description": "Alert on document processing failures",
        "severity": 2,
        "enabled": true,
        "evaluationFrequency": "PT5M",
        "scopes": [
          "[parameters('appInsightsResourceId')]"
        ],
        "windowSize": "PT15M",
        "criteria": {
          "allOf": [
            {
              "query": "            customEvents\r\n            | where name == \"DocumentProcessingFailed\" or name == \"document_processing_failed\"\r\n            | summarize FailureCount = count() by bin(timestamp, 15m)\r\n            | where FailureCount > 5\r\n          ",
              "timeAggregation": "Count",
              "operator": "GreaterThan",
              "threshold": 0,
              "failingPeriods": {
                "numberOfEvaluationPeriods": 1,
                "minFailingPeriodsToAlert": 1
              }
            }
          ]
        },
        "actions": {
          "actionGroups": "[if(or(not(equals(parameters('actionGroupId'), '')), not(parameters('enableAlerts'))), createArray(variables('effectiveActionGroupId')), createArray())]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/actionGroups', format('{0}-alerts-{1}', parameters('prefix'), parameters('environment')))]"
      ]
    }
