      "value": "[if(and(parameters('enableAlerts'), not(equals(parameters('cosmosDbResourceId'), ''))), resourceId('Microsoft.Insights/scheduledQueryRules', format('{0}-alert-dlq-depth-{1}', parameters('prefix'), parameters('environment'))), '')]"
    },
    "restartAlertId": {
      "type": "string",
      "metadata": {
