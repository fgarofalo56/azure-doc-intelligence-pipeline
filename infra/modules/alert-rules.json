  "resources": [
    {
      "condition": "[and(parameters('enableAlerts'), equals(parameters('actionGroupId'), ''))]",
      "type": "Microsoft.Insights/actionGroups",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}-alerts-{1}', parameters('prefix'), parameters('environment'))]",
      "location": "Global",
      "tags": "[parameters('tags')]",
      "properties": {
        "groupShortName": "[format('{0}alerts', parameters('prefix'))]",
        "enabled": true,
        "emailReceivers": [],
