      "type": "Microsoft.Insights/metricAlerts",
      "apiVersion": "2018-03-01",
      "name": "[format('{0}-alert-http5xx-{1}', parameters('prefix'), parameters('environment'))]",
      "location": "Global",
      "tags": "[parameters('tags')]",
      "properties": {
        "description": "Alert on HTTP 5xx server errors",
        "severity": 1,
        "enabled": true,
        "scopes": [
          "[parameters('functionAppResourceId')]"
        ],
        "evaluationFrequency": "PT1M",
        "windowSize": "PT5M",
        "criteria": {
          "odata.type": "Microsoft.Azure.Monitor.SingleResourceMultipleMetricCriteria",
          "allOf": [
            {
              "name": "Http5xxErrors",
              "metricName": "Http5xx",
              "metricNamespace": "Microsoft.Web/sites",
              "operator": "GreaterThan",
              "threshold": 0,
              "timeAggregation": "Total",
              "criterionType": "StaticThresholdCriterion"
            }
          ]
        },
        "actions": "[if(or(not(equals(parameters('actionGroupId'), '')), not(parameters('enableAlerts'))), createArray(createObject('actionGroupId', variables('effectiveActionGroupId'), 'webHookProperties', createObject())), createArray())]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/actionGroups', format('{0}-alerts-{1}', parameters('prefix'), parameters('environment')))]"
      ]
