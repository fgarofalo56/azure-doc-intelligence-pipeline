      "type": "Microsoft.Insights/metricAlerts",
      "apiVersion": "2018-03-01",
      "name": "[format('{0}-alert-error-rate-{1}', parameters('prefix'), parameters('environment'))]",
      "location": "Global",
      "tags": "[parameters('tags')]",
      "properties": {
        "description": "[format('Alert when error rate exceeds {0}%', parameters('errorRateThreshold'))]",
        "severity": 1,
        "enabled": true,
        "scopes": [
